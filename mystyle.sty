% --- Automatically wrap standard \cite inside parentheses (supporting optional arguments) ---
\usepackage{xparse}
\NewDocumentCommand{\robustcite}{o o m}{%
  \IfValueTF{#1}{%
    \IfValueTF{#2}{\parencite[#1][#2]{#3}}{\parencite[#1]{#3}}%
  }{\parencite{#3}}%
}
\let\cite\robustcite

