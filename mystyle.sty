% --- THEOREMS & CUSTOM LISTS CONFIGURATION ---
\makeatletter % Enforce internal macro reading safely

% Define theorem-like elements bound to chapter numbering
\newtheorem{theorem}{Theorem}[chapter]
\newtheorem{corollary}[theorem]{Corollary}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{axiom}[theorem]{Axiom}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{exercise}[theorem]{Exercise}
\newtheorem{question}[theorem]{Question}
\newtheorem{problem}[theorem]{Problem}
\newtheorem{example}[theorem]{Example}
\newtheorem{remark}[theorem]{Remark}

% --- Custom Lists Infrastructure ---
\newcommand{\listtheoremsname}{List of Theorems}
\newcommand{\listofmytheorems}{\chapter*{\listtheoremsname}\@starttoc{thm}}
\newcommand{\mytheorems}[1]{%
  \addcontentsline{thm}{mytheorems}{\protect\numberline{\thetheorem}#1}\par%
}
\newcommand{\l@mytheorems}{\@dottedtocline{1}{1.5em}{2.3em}}

\newcommand{\listequationsname}{List of Equations}
\newcommand{\listofmyequations}{\chapter*{\listequationsname}\@starttoc{equ}}
\newcommand{\myequations}[1]{%
  \addcontentsline{equ}{myequations}{\protect\numberline{\theequation}#1}\par%
}
\newcommand{\l@myequations}{\@dottedtocline{1}{1.5em}{2.3em}}

\newcommand{\listdefinitionsname}{List of Definitions}
\newcommand{\listofmydefinitions}{\chapter*{\listdefinitionsname}\@starttoc{def}}
\newcommand{\mydefinitions}[1]{%
  \addcontentsline{def}{mydefinitions}{\protect\numberline{\thedefinition}#1}\par%
}
\newcommand{\l@mydefinitions}{\@dottedtocline{1}{1.5em}{2.3em}}

\newcommand{\listcorollariesname}{List of Corollaries}
\newcommand{\listofmycorollaries}{\chapter*{\listcorollariesname}\@starttoc{cor}}
\newcommand{\mycorollaries}[1]{%
  \addcontentsline{cor}{mycorollaries}{\protect\numberline{\thecorollary}#1}\par%
}
\newcommand{\l@mycorollaries}{\@dottedtocline{1}{1.5em}{2.3em}}

\newcommand{\listlemmasname}{List of Lemmas}
\newcommand{\listofmylemmas}{\chapter*{\listlemmasname}\@starttoc{lem}}
\newcommand{\mylemmas}[1]{%
  \addcontentsline{lem}{mylemmas}{\protect\numberline{\thelemma}#1}\par%
}
\newcommand{\l@mylemmas}{\@dottedtocline{1}{1.5em}{2.3em}}

\newcommand{\listpropositionsname}{List of Propositions}
\newcommand{\listofmypropositions}{\chapter*{\listpropositionsname}\@starttoc{prop}}
\newcommand{\mypropositions}[1]{%
  \addcontentsline{prop}{mypropositions}{\protect\numberline{\theproposition}#1}\par%
}
\newcommand{\l@mypropositions}{\@dottedtocline{1}{1.5em}{2.3em}}

% --- Automated Chapter Spacing for Custom Lists ---
\pretocmd{\chapter}{%
  \addtocontents{thm}{\protect\addvspace{10pt}}%
  \addtocontents{equ}{\protect\addvspace{10pt}}%
  \addtocontents{def}{\protect\addvspace{10pt}}%
  \addtocontents{cor}{\protect\addvspace{10pt}}%
  \addtocontents{lem}{\protect\addvspace{10pt}}%
  \addtocontents{prop}{\protect\addvspace{10pt}}%
}{}{}

\@addtoreset{theorem}{chapter}
\makeatother % Close macro reading safely

% --- ENDNOTES CONFIGURATION ---
\usepackage{enotez}
\setenotez{
  list-heading = {\section*{#1}},
  split = chapter,
  split-title = {Notes for Chapter <ref>}
}
