% --- Modern Code Highlighting with tcolorbox and minted ---
\usepackage[minted, most]{tcolorbox}

% Python Style (Boxed Title Left, with Python Indicator)
\NewTCBListing{pycode}{ m }{%
  listing only,
  listing engine=minted,
  enhanced,
  minted language=python,
  minted options={
    fontsize=\small,
    breaklines,
    linenos,
    numbersep=8pt
  },
  colback=gray!3!white,
  colframe=gray!75!black,
  title={$\triangleright$ Code: #1}, % Distinct prefix marker
  fonttitle=\bfseries,
  coltitle=white,
  attach boxed title to top left={yshift=-3mm, xshift=3mm},
  boxed title style={colback=gray!75!black, sharp corners},
  left=25pt,
  top=5pt,
  bottom=5pt
}

% Define a custom style for Zsh terminal (Black Text on White)
\NewTCBListing{zshbox}{ m }{%
  listing only,
  listing engine=minted,
  enhanced,
  minted language=zsh,
  minted options={fontsize=\small, breaklines},
  colback=white,            % White background
  colframe=gray!60!black,   % Slate frame
  coltext=black,            % Black text
  title={\texttt{\$} Shell: #1},
  fonttitle=\bfseries\small,
  coltitle=white,
  attach boxed title to top left={yshift=-3mm, xshift=3mm},
  boxed title style={colback=gray!60!black, sharp corners}
}

% --- HEADERS & FOOTERS CONFIGURATION (Two-Sided Page Numbering) ---
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}

% --- Page number on outer edges ---
\fancyfoot[RO]{\normalfont\thepage}
\fancyfoot[LE]{\normalfont\thepage}

% --- Clear page numbers on completely blank pages generated by clearpage ---
\makeatletter
\renewcommand{\cleardoublepage}{%
  \clearpage\if@twoside \ifodd\c@page\else
  \thispagestyle{empty}%
  \hbox{}\newpage\if@twocolumn\hbox{}\newpage\fi\fi\fi
}
\makeatother

\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% --- Force chapter opening pages to use the same outer-edge numbering layout ---
\fancypagestyle{plain}{%
  \fancyhf{}
  \fancyfoot[RO]{\normalfont\thepage}
  \fancyfoot[LE]{\normalfont\thepage}
  \renewcommand{\headrulewidth}{0pt}
}

